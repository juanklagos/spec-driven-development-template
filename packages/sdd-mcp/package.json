{
  "name": "@juanklagos/sdd-mcp",
  "version": "2.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "sdd-mcp": "./dist/index.js",
    "sdd-mcp-http": "./dist/http.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "start": "tsx src/index.ts",
    "start:http": "tsx src/http.ts",
    "prepack": "npm run build && node ../../scripts/build-builder-ui.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@juanklagos/sdd-core": "2.1.0",
    "zod": "^3.25.76"
  },
  "description": "Spec-Driven Development MCP server: specs, plans, gates, consent, status, logbook tools and a visual dashboard. Bilingual EN/ES.",
  "files": [
    "dist",
    "LICENSE",
    "NOTICE",
    "TEMPLATE-OUTPUT.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juanklagos/spec-driven-development-template.git",
    "directory": "packages/sdd-mcp"
  },
  "keywords": [
    "sdd",
    "spec-driven-development",
    "mcp",
    "model-context-protocol",
    "specs"
  ],
  "author": "Juan Carlos Alvarez Lagos",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "mcpName": "io.github.juanklagos/sdd-mcp"
}
