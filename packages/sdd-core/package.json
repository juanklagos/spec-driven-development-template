{
  "name": "@juanklagos/sdd-core",
  "version": "2.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:framework-payload": "node ../../scripts/build-framework-payload.mjs",
    "prepack": "npm run build:framework-payload",
    "prepublishOnly": "npm run build"
  },
  "description": "Typed core operations for Spec-Driven Development: workspaces, specs, validation, gate, consent, status and logbook. Bilingual EN/ES.",
  "files": [
    "dist",
    "framework",
    "LICENSE",
    "NOTICE",
    "TEMPLATE-OUTPUT.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juanklagos/spec-driven-development-template.git",
    "directory": "packages/sdd-core"
  },
  "keywords": [
    "sdd",
    "spec-driven-development",
    "specs",
    "workflow"
  ],
  "author": "Juan Carlos Alvarez Lagos",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
