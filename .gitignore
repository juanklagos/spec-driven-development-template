.DS_Store
Thumbs.db
# STATUS.md is generated by scripts/generate-status.sh but is COMMITTED on
# purpose: /sdd:help and the docs read it as the workspace snapshot. It was
# listed here while already tracked, which ignored nothing and only implied it
# could drift. Regenerate it before committing instead.
analysis/
docs/roadmap.md
docs/roadmap.mmd
node_modules/
.sdd/*
!.sdd/user-consent.log
packages/*/dist/
# Generated at pack time by scripts/build-framework-payload.mjs.
packages/sdd-core/framework/

# Transient spec-allocation lock (scripts/new-spec.sh and sdd-core reserveSpecDir).
# Always released; only ever on disk if a process was killed mid-allocation.
specs/.lock/
**/specs/.lock/
