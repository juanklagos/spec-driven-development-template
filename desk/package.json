{
  "name": "sdd-desk",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "license": "MIT",
  "description": "SDD Desk: the SDD Builder in its own window, hosting the SDD server and its MCP endpoint.",
  "// packaging metadata": "author and homepage are not decoration: electron-builder refuses to build the Linux targets without them, and .deb takes its Maintainer field from author.",
  "author": "Juan Carlos Alvarez Lagos <praxisstudio.co@gmail.com>",
  "homepage": "https://github.com/juanklagos/spec-driven-development-template",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juanklagos/spec-driven-development-template.git",
    "directory": "desk"
  },
  "main": "dist/main/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "icon": "electron scripts/build-icon.mjs",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron .",
    "dist": "npm run build && electron-builder --config electron-builder.yml",
    "dist:dir": "npm run build && electron-builder --config electron-builder.yml --dir"
  },
  "dependencies": {
    "@juanklagos/sdd-core": "file:../packages/sdd-core",
    "@juanklagos/sdd-mcp": "file:../packages/sdd-mcp",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3",
    "typescript": "^5.9.3"
  }
}
