{
  "name": "spec-driven-development-template",
  "private": true,
  "version": "2.1.0",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "npm run build --workspaces --if-present",
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "test": "npm run mcp:test",
    "mcp:start": "npm --workspace @juanklagos/sdd-mcp run start",
    "mcp:http:start": "npm --workspace @juanklagos/sdd-mcp run start:http",
    "mcp:build": "npm --workspace @juanklagos/sdd-mcp run build",
    "mcp:test": "npm run build && node scripts/test-mcp-integration.mjs",
    "mcp:smoke": "npm run build && node scripts/smoke-test-mcp.mjs",
    "mcp:http:smoke": "npm run build && node scripts/smoke-test-mcp-http.mjs",
    "mcp:pack:smoke": "npm run build && node scripts/smoke-test-npm-package.mjs",
    "builder:build": "cd builder && npm install && npm run build"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  }
}
